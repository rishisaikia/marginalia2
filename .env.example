# Environment Variables

# Required for local development (netlify dev uses this automatically)
# Never commit .env to git — it's in .gitignore
# In production, set these in the Netlify dashboard (Site settings → Environment variables)

GITHUB_TOKEN=your_github_personal_access_token_here

# Auth (Netlify Identity) — no extra env vars needed.
# Enable Identity in the Netlify dashboard: Site settings → Identity → Enable Identity
# Optional: enable Google OAuth under Identity → External providers

# Saves (Netlify Blobs) — no extra env vars needed.
# Blobs are auto-available on deployed Netlify sites.
# Note: Blobs require a *deployed* site; they don't work in local netlify dev.
